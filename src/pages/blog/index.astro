---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const grouped: { year: number; posts: typeof posts }[] = [];
for (const post of posts) {
	const year = post.data.pubDate.getFullYear();
	let group = grouped.find((g) => g.year === year);
	if (!group) {
		group = { year, posts: [] };
		grouped.push(group);
	}
	group.posts.push(post);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description="Writing on strategy, emerging tech, analytics, and building by Jordan Avery." />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-intro">
				<h1>Writing</h1>
				<p class="lede">
					Working notes on strategy, emerging technology, analytics, and what I'm
					building. Some essays, some thinking out loud, some pieces I'll revisit
					when I know more.
				</p>
			</section>

			{grouped.map((group) => (
				<section class="year-group">
					<h2 class="year">{group.year}</h2>
					<ul class="post-list">
						{group.posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-row">
										<span class="post-title">{post.data.title}</span>
										<FormattedDate date={post.data.pubDate} />
									</div>
									{post.data.description && <p class="post-description">{post.data.description}</p>}
								</a>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-intro {
		margin-bottom: 3rem;
	}
	.blog-intro .lede {
		font-size: 1.15rem;
		max-width: 60ch;
		color: var(--text);
	}
	.year-group {
		margin-bottom: 3rem;
	}
	.year {
		font-size: 1rem;
		font-family: var(--font-sans);
		font-weight: 500;
		color: var(--text-muted);
		letter-spacing: 0.08em;
		margin-bottom: 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		margin-bottom: 0;
	}
	.post-list > li > a {
		display: block;
		padding: 1.25rem 0;
		border-bottom: 1px solid var(--border);
		color: var(--text);
	}
	.post-list > li:last-child > a {
		border-bottom: none;
	}
	.post-list > li > a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.post-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 0.35rem;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.2rem;
		font-weight: 600;
	}
	.post-row time {
		font-size: 0.85rem;
		color: var(--text-muted);
		white-space: nowrap;
	}
	.post-description {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin: 0;
	}
</style>